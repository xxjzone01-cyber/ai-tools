generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks      Task[]
  timeRecords TimeRecord[]
  categories Category[]
  predictions Prediction[]

  @@map("users")
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  priority    Priority @default(MEDIUM)
  status      Status   @default(TODO)
  dueDate     DateTime?
  estimatedTime Int?    // 预估时间（分钟）
  actualTime   Int?     // 实际时间（分钟）
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  timeRecords TimeRecord[]

  @@map("tasks")
}

model Category {
  id     String @id @default(cuid())
  name   String
  color  String
  userId String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks   Task[]
  timeRecords TimeRecord[]

  @@map("categories")
}

model TimeRecord {
  id        String   @id @default(cuid())
  startTime DateTime
  endTime   DateTime
  duration  Int      // 持续时间（分钟）
  notes     String?
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id])
  categoryId String?
  category  Category? @relation(fields: [categoryId], references: [id])

  @@map("time_records")
}

model Prediction {
  id          String   @id @default(cuid())
  taskTitle   String
  predictedTime Int      // 预测时间（分钟）
  confidence  Float    // 置信度（0-1）
  createdAt   DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("predictions")
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum Status {
  TODO
  IN_PROGRESS
  COMPLETED
  CANCELLED
}